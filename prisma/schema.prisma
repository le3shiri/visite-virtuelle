generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- PORTFOLIO ---
model Project {
  id                String   @id @default(cuid())
  title             String
  slug              String   @unique
  category          String
  surface           Int?
  matterportUrl     String?
  videoUrl          String?
  coverImage        String?
  status            String   @default("DRAFT") // PUBLISHED, DRAFT
  isFeatured        Boolean  @default(false)
  
  // Multilingual content (JSON)
  description       Json?    // { fr: "", en: "", ar: "" }
  challenge         Json?
  solution          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// --- BLOG ---
model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  content       Json?    // { fr: "", en: "", ar: "" }
  status        String   @default("DRAFT")
  isPinned      Boolean  @default(false)
  publishDate   DateTime?
  coverImage    String?
  
  createdAt     DateTime @default(now())
}

// --- BOOKINGS ---
model Booking {
  id            String   @id @default(cuid())
  reference     String   @unique // e.g., BK-7721
  clientName    String
  clientEmail   String
  date          DateTime
  timeSlot      String
  projectType   String   // Découverte, Professionnel, etc.
  location      String?
  status        String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  
  createdAt     DateTime @default(now())
}

// --- BLOCKED DATES ---
model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
}

// --- INQUIRIES ---
model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --- SITE SETTINGS ---
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., 'company_profile'
  value     Json     // Dynamic configuration
}

// --- TESTIMONIALS ---
model Testimonial {
  id        String   @id @default(cuid())
  client    String
  role      String?
  content   String
  rating    Float    @default(5.0)
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}

// --- PRICING PLANS ---
model PricingPlan {
  id          String   @id @default(cuid())
  name        String
  price       String
  status      String   @default("ACTIVE")
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- TIME SLOTS ---
model TimeSlot {
  id        String   @id @default(cuid())
  time      String   @unique
  isActive  Boolean  @default(true)
}

// --- ADMIN USERS ---
model account_user {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account      String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  email        String?  @unique @db.VarChar(255)
  display_name String?  @unique @db.VarChar(255)
  role         String?  @default("ADMIN") @db.VarChar(50)
  is_active    Boolean? @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}
